<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="100dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analytics"
            android:textColor="@color/cyber_cyan"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your focus summary"
            android:textColor="#8A8A95"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <!-- Main Summary Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#12121A"
            android:padding="18dp"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today’s Focus Report"
                android:textColor="#E6E6EA"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtFocusStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Focus Mode: Off"
                android:textColor="#8A8A95"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/txtSelectedApps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selected apps: 0"
                android:textColor="#8A8A95"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/txtDailyLimit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily limit: 1 hr"
                android:textColor="#8A8A95"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Stats Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="18dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#12121A"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/txtBlockedAttempts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/cyber_cyan"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blocked attempts"
                    android:textColor="#8A8A95"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#12121A"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/txtContinueCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/cyber_cyan"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continue clicks"
                    android:textColor="#8A8A95"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Most Triggered App Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#12121A"
            android:padding="18dp"
            android:layout_marginTop="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Most Triggered App"
                android:textColor="#8A8A95"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMostTriggeredApp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No data yet"
                android:textColor="#E6E6EA"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

        </LinearLayout>
        <!-- App-wise Breakdown Card -->
        <LinearLayout
            android:id="@+id/layoutAppBreakdownCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#12121A"
            android:padding="18dp"
            android:layout_marginTop="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="App-wise Breakdown"
                android:textColor="#E6E6EA"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Popup and action history for each app"
                android:textColor="#8A8A95"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:id="@+id/layoutAppBreakdownContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:id="@+id/txtNoAppBreakdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No app activity yet"
                    android:textColor="#60606A"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Analytics will update as SnapOut blocks distractions during Focus Mode."
            android:textColor="#60606A"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.25"
            android:layout_marginTop="20dp" />

    </LinearLayout>

</ScrollView>