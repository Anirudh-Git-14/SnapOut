<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050508">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#0A0A0E"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FOCUS CONTROL"
            android:textColor="#666677"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:fontFamily="sans-serif-medium" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toStartOf="@id/switchFocusMode"
                android:layout_alignParentStart="true"
                android:layout_marginEnd="16dp">

                <TextView
                    android:id="@+id/txtToggleStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Focus Mode Off"
                    android:textColor="#E6E6EA"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/txtDefenseMeme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose apps you want to avoid during focus."
                    android:textColor="#8A8A95"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:letterSpacing="0.02"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchFocusMode"
                android:layout_width="64dp"
                android:layout_height="48dp"
                android:minHeight="48dp"
                android:minWidth="48dp"
                android:padding="8dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:track="@drawable/bg_focus_switch_track"
                android:thumb="@drawable/bg_focus_switch_thumb"
                android:checked="false" />

        </RelativeLayout>

        <TextView
            android:id="@+id/txtSelectedCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#12121A"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:text="0 apps selected"
            android:textColor="#00F0FF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:fontFamily="sans-serif-medium" />
        <LinearLayout
            android:id="@+id/layoutDailyLimit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:background="#12121A"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily limit"
                android:textColor="#8A8A95"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLimitMinus"
                    android:layout_width="52dp"
                    android:layout_height="42dp"
                    android:text="-"
                    android:textColor="#00F0FF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:background="#15151C" />

                <TextView
                    android:id="@+id/txtDailyLimit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="1 hr"
                    android:textColor="#E6E6EA"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLimitPlus"
                    android:layout_width="52dp"
                    android:layout_height="42dp"
                    android:text="+"
                    android:textColor="#00F0FF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:background="#15151C" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select distracting apps"
        android:textColor="#8A8A95"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginStart="20dp"
        android:layout_marginTop="22dp"
        android:layout_marginBottom="10dp"
        android:letterSpacing="0.08"
        android:fontFamily="sans-serif-medium" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAppSelection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="80dp" />

</LinearLayout>